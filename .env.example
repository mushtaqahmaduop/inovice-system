# Copy to .env.local and fill in. NEVER commit any .env* file (CLAUDE.md §1).
# Two Supabase projects exist: STAGING and PRODUCTION (BUILD_PHASES 0.2/0.4).
# Local dev + preview deploys point at STAGING. Production values live only
# in Vercel's production environment.

# ── Supabase (staging values for local dev) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Postgres connection string (Supabase pooler, transaction mode)
DATABASE_URL=
# Session pooler (port 5432) — drizzle-kit migrations only
DATABASE_URL_MIGRATIONS=
# Service role key — rare, explicitly-justified admin operations ONLY
# (SCHEMA_DESIGN §5 service-role policy). Never in client code.
SUPABASE_SERVICE_ROLE_KEY=

# ── Sentry (task 7.2 wires the SDK; keys reserved here) ─────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Resend deliberately absent — task 6.4 is blocked on Q-11–17 (BUILD_PHASES).
